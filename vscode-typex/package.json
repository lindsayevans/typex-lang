{
  "name": "vscode-typex",
  "displayName": "TypeX Language Support",
  "description": "Syntax highlighting for the TypeX programming language (.tx files)",
  "version": "0.1.0",
  "publisher": "typex",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "typex",
        "aliases": [
          "TypeX",
          "typex"
        ],
        "extensions": [
          ".tx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "typex",
        "scopeName": "source.typex",
        "path": "./syntaxes/typex.tmLanguage.json"
      }
    ]
  }
}
