{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TypeX",
  "scopeName": "source.typex",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#char-literals" },
    { "include": "#numbers" },
    { "include": "#arrow" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#constants" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.typex",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.typex",
          "match": "//.*$"
        }
      ]
    },
    "arrow": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.typex",
          "match": "=>"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.typex",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.typex",
          "match": "\\\\[ntr\\\\\"']"
        },
        {
          "name": "variable.other.format.typex",
          "match": "\\{[^}]*\\}"
        }
      ]
    },
    "char-literals": {
      "name": "string.quoted.single.typex",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.typex",
          "match": "\\\\[ntr\\\\\"']"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.typex",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.typex",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.typex",
          "match": "\\b(if|else|for|in|of|switch|case|default|match|return|break)\\b"
        },
        {
          "name": "keyword.declaration.typex",
          "match": "\\b(let|const|function|type|enum|import|export|from)\\b"
        },
        {
          "name": "keyword.operator.typex",
          "match": "\\b(null|true|false)\\b"
        },
        {
          "name": "keyword.other.typex",
          "match": "\\b(panic|print|println)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.typex",
          "match": "\\b(int8|int16|int32|int64|int|uint8|uint16|uint32|uint64|uint|float32|float64|float|boolean|char|string|null)\\b"
        },
        {
          "name": "support.type.builtin.typex",
          "match": "\\b(Array|Result|Date|Time|DateTime)\\b"
        },
        {
          "name": "support.type.result.typex",
          "match": "\\b(Ok|Err)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.typex",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.typex",
          "match": "(==|!=|<=|>=)"
        },
        {
          "name": "keyword.operator.logical.typex",
          "match": "(&&|\\|\\|)"
        },
        {
          "name": "keyword.operator.assignment.typex",
          "match": "(?<![=!<>])=(?![=>])"
        },
        {
          "name": "keyword.operator.arithmetic.typex",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.comparison.typex",
          "match": "(<|>)"
        },
        {
          "name": "keyword.operator.pipe.typex",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.ternary.typex",
          "match": "\\?"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.typex",
          "match": ";"
        },
        {
          "name": "punctuation.separator.typex",
          "match": ","
        },
        {
          "name": "punctuation.accessor.typex",
          "match": "\\."
        },
        {
          "name": "punctuation.definition.block.typex",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.bracket.typex",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.definition.paren.typex",
          "match": "[()]"
        },
        {
          "name": "punctuation.definition.generic.typex",
          "match": "[<>]"
        },
        {
          "name": "punctuation.definition.colon.typex",
          "match": ":"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "variable.other.constant.typex",
          "match": "\\b([A-Z][A-Z0-9_]*)\\b"
        },
        {
          "name": "entity.name.type.typex",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.typex",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
